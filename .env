# This file contains environment variables for the DashFlow CRM application.
# It should be kept secure and not committed to public version control.

# API Configuration
# Base URL for the CRM backend services
API_BASE_URL=https://difmo-crm-backend-2uwg.onrender.com/api

# Google Maps API Keys
# Access to Google Maps features (requires Maps SDK for Android and iOS enabled in Console)
# Currently hardcoded in AndroidManifest.xml: AIzaSyClF12i0eHy7Nrig6EYu8Z4U5DA2zC09OI
GOOGLE_MAPS_API_KEY_ANDROID=AIzaSyClF12i0eHy7Nrig6EYu8Z4U5DA2zC09OI
GOOGLE_MAPS_API_KEY_IOS=YOUR_GOOGLE_MAPS_API_KEY

# Application Settings
# Timeout duration for API requests in seconds
API_TIMEOUT_SECONDS=30
